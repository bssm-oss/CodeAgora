{
  "name": "@codeagora/review",
  "version": "0.1.0-rc.6",
  "type": "module",
  "description": "Multi-LLM code review pipeline — parallel reviewers, structured debate, consensus verdict",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bssm-oss/CodeAgora.git"
  },
  "homepage": "https://github.com/bssm-oss/CodeAgora#readme",
  "bugs": {
    "url": "https://github.com/bssm-oss/CodeAgora/issues"
  },
  "keywords": [
    "code-review",
    "llm",
    "multi-agent",
    "cli",
    "ai",
    "static-analysis"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "packages/cli/dist/**/*.js",
    "packages/shared/src/data/**",
    "scripts/postinstall.cjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codeagora": "./packages/cli/dist/index.js",
    "agora": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/scripts/**/*.{js,mjs,ts}\" \"src/tests/**/*.ts\" \"scripts/**/*.{js,mjs,ts}\" \"vitest.config.ts\" \"eslint.config.js\" --quiet",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run src/tests/redaction-boundaries.test.ts src/tests/config-path-security.test.ts src/tests/github-action-diff-path-security.test.ts src/tests/github-action-sarif-path.test.ts src/tests/large-diff-security-priority.test.ts src/tests/utils-path-validation.test.ts src/tests/desktop-webdriver-security.test.ts packages/core/src/tests/prompt-injection-boundaries.test.ts packages/mcp/src/tests/critical-errors.test.ts packages/github/src/tests/critical-github-errors.test.ts",
    "dev": "pnpm --filter @codeagora/cli dev",
    "desktop:evidence": "pnpm --filter @codeagora/desktop evidence",
  "desktop:bundle": "pnpm --filter @codeagora/desktop tauri:build",
  "desktop:bundle-smoke": "pnpm --filter @codeagora/desktop bundle:smoke",
  "desktop:app-e2e": "pnpm --filter @codeagora/desktop app:e2e",
  "desktop:live-review-smoke": "pnpm --filter @codeagora/desktop live:review-smoke",
  "desktop:macos-webdriver-e2e": "pnpm --filter @codeagora/desktop macos:webdriver-e2e",
  "desktop:smoke": "pnpm --filter @codeagora/desktop smoke",
  "desktop:visual-qa": "pnpm --filter @codeagora/desktop visual:qa",
    "rc:desktop-gate": "pnpm --filter @codeagora/desktop typecheck && pnpm --filter @codeagora/desktop smoke && pnpm --filter @codeagora/desktop tauri:check && pnpm --filter @codeagora/desktop app:e2e && pnpm --filter @codeagora/desktop macos:webdriver-e2e && pnpm --filter @codeagora/desktop visual:qa && pnpm --filter @codeagora/desktop evidence && pnpm --filter @codeagora/desktop bundle:smoke",
    "evidence:manifest": "node scripts/evidence-manifest.mjs",
    "build:action": "node scripts/build-action.mjs",
    "release:beta-smoke": "node scripts/beta-smoke.mjs",
    "bench:fn": "tsx scripts/bench-fn.ts",
    "bench:fn:run": "tsx scripts/bench-fn-run.ts",
    "bench:fn:compare": "tsx scripts/bench-fn-compare.ts",
    "bench:reference": "tsx scripts/bench-reference-check.ts",
    "bench:ci": "pnpm bench:fn -- --validate-only && pnpm bench:reference -- --validate-only",
    "bench:rate-limit": "tsx scripts/bench-rate-limit-sim.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/baseten": "^1.0.38",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/deepinfra": "^2.0.39",
    "@ai-sdk/fireworks": "^2.0.40",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/huggingface": "^1.0.37",
    "@ai-sdk/moonshotai": "^2.0.10",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@ai-sdk/perplexity": "^3.0.23",
    "@clack/prompts": "^1.1.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.111",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.5",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "tsup": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.2.0"
  }
}
