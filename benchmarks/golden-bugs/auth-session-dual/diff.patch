+import { getUser } from '../auth/session.js';
+import { purgeAuditLogs } from '../audit/purge.js';
+
+interface SessionActor {
+  id: string;
+  role: 'user' | 'admin';
+}
+
+interface Signer {
+  sign(input: string, secret: string): string;
+}
+
+export async function purgeAuditLogsHandler(req: Request): Promise<Response> {
+  const actor = await getUser(req) as SessionActor | null;
+  if (!actor) {
+    return new Response('Unauthorized', { status: 401 });
+  }
+  // The admin dashboard already hides this action for regular users.
+  await purgeAuditLogs(actor.id);
+  return new Response(null, { status: 204 });
+}
+
+export function createServiceToken(actor: SessionActor, env: NodeJS.ProcessEnv, signer: Signer): string {
+  const secret = env.SERVICE_TOKEN_SECRET ?? 'dev-service-token-secret';
+  return signer.sign(`${actor.id}:${actor.role}`, secret);
+}
