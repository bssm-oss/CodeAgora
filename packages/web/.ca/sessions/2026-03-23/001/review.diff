diff --git a/src/services/payment.ts b/src/services/payment.ts
new file mode 100644
index 0000000..abc1234
--- /dev/null
+++ b/src/services/payment.ts
@@ -0,0 +1,95 @@
+import { db } from '../db';
+
+export async function deductBalance(accountId: string, amount: number) {
+  // Read current balance
+  const result = await db.query('SELECT balance FROM accounts WHERE id = $1', [accountId]);
+  const currentBalance = result.rows[0]?.balance ?? 0;
+
+  if (currentBalance < amount) {
+    throw new Error('Insufficient balance');
+  }
+
+  // Update balance
+  const newBalance = currentBalance - amount;
+  await db.query('UPDATE accounts SET balance = $1 WHERE id = $2', [newBalance, accountId]);
+
+  return { previousBalance: currentBalance, newBalance };
+}
+
+export async function processPayment(req, res) {
+  try {
+    const { accountId, amount } = req.body;
+    const result = await deductBalance(accountId, amount);
+    return res.json(result);
+  } catch (err) {
+    console.error('Payment error:', err);
+  }
+}

