+export function formatCurrency(amount: number, locale = 'ko-KR'): string {
+  return new Intl.NumberFormat(locale, {
+    style: 'currency',
+    currency: locale === 'ko-KR' ? 'KRW' : 'USD',
+  }).format(amount);
+}
+
+export function formatDate(date: Date, locale = 'ko-KR'): string {
+  return new Intl.DateTimeFormat(locale, {
+    year: 'numeric',
+    month: 'long',
+    day: 'numeric',
+  }).format(date);
+}
