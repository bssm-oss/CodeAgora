{
  "name": "@codeagora/web",
  "version": "2.2.2",
  "description": "CodeAgora web dashboard — review history, analytics, and real-time monitoring",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justn-hyeok/CodeAgora.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/justn-hyeok/CodeAgora#readme",
  "keywords": [
    "codeagora",
    "dashboard",
    "code-review",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/frontend/**"
  ],
  "scripts": {
    "build": "tsup && vite build",
    "build:frontend": "vite build",
    "dev": "tsx src/server/index.ts",
    "dev:frontend": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.0",
    "hono": "^4.7.0",
    "pino": "^10.3.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "devDependencies": {
    "@codeagora/core": "workspace:*",
    "@codeagora/shared": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^29.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "tsup": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^6.3.0",
    "vitest": "^1.2.0"
  }
}
