{
  "name": "@codeagora/github",
  "version": "0.1.0-rc.6",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./*.js": {
      "development": "./src/*.ts",
      "import": "./dist/*.js"
    },
    "./*": {
      "development": "./src/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@codeagora/core": "workspace:*",
    "@codeagora/shared": "workspace:*",
    "@octokit/rest": "^22.0.1"
  }
}
