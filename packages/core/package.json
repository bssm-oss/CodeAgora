{
  "name": "@codeagora/core",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./*.js": {
      "development": "./src/*.ts",
      "import": "./dist/*.js"
    },
    "./*": {
      "development": "./src/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@codeagora/shared": "workspace:*",
    "ai": "^6.0.111",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "yaml": "^2.8.2",
    "zod": "^3.22.4",
    "commander": "^14.0.3"
  }
}
