{
  "name": "@codeagora/mcp",
  "version": "0.1.0",
  "description": "CodeAgora MCP server — Claude Code integration for AI-powered code review",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bssm-oss/CodeAgora.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/bssm-oss/CodeAgora#readme",
  "keywords": [
    "codeagora",
    "mcp",
    "model-context-protocol",
    "claude",
    "code-review"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./version.js": {
      "development": "./src/version.ts",
      "import": "./dist/version.js"
    }
  },
  "bin": {
    "codeagora-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/data/*.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/data && cp ../shared/src/data/*.json dist/data/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.111",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@codeagora/cli": "workspace:*",
    "@codeagora/core": "workspace:*",
    "@codeagora/shared": "workspace:*"
  }
}
