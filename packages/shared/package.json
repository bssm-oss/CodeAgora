{
  "name": "@codeagora/shared",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*.js": {
      "development": "./src/*.ts",
      "import": "./dist/*.js"
    },
    "./*": {
      "development": "./src/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsup && cp src/data/*.json dist/data/ && mkdir -p dist/i18n && cp -R src/i18n/locales dist/i18n/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "zod": "^3.22.4"
  }
}
