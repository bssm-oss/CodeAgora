{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeAgora",
  "version": "0.1.0",
  "identifier": "dev.codeagora.desktop",
  "build": {
    "beforeBuildCommand": "pnpm --filter @codeagora/desktop build",
    "beforeDevCommand": "pnpm --filter @codeagora/desktop build:watch",
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CodeAgora",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNjAwRTYzMkZDNkYxQjYKUldTMjhjWXZZdzVnNGwzcnFsRDZQRnlMa24vSjRKQjlncW9OTXNUeUJNdlhYeUZMdjBXTXkyQWEK",
      "endpoints": [
        "https://github.com/bssm-oss/CodeAgora/releases/download/desktop-0.1/latest-0.1.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
