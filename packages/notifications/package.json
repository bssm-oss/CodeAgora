{
  "name": "@codeagora/notifications",
  "version": "2.1.0-rc.1",
  "description": "CodeAgora notification webhooks — Discord and Slack integration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bssm-oss/CodeAgora.git",
    "directory": "packages/notifications"
  },
  "homepage": "https://github.com/bssm-oss/CodeAgora#readme",
  "keywords": ["codeagora", "notifications", "discord", "slack", "webhooks"],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./webhook.js": {
      "import": "./dist/webhook.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@codeagora/core": "workspace:*",
    "@codeagora/shared": "workspace:*"
  }
}
